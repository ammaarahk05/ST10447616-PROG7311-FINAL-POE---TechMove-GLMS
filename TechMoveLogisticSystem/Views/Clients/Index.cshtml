@model IEnumerable<TechMoveLogisticSystem.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="page-header">
    <h2 class="page-title">Clients</h2>

    <a asp-action="Create" class="btn-soft">+ New Client</a>
</div>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="custom-card h-100">

                <!-- HEADER -->
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <h5 style="margin:0; font-family:'Playfair Display', serif; color:#6B2E2E;">
                        @item.Name
                    </h5>
                </div>

                <hr style="border-color:#E0D6C8;" />

                <!-- DETAILS -->
                <div style="margin-bottom:10px;">
                    <span class="label">Contact Details</span>
                    <p style="margin:0;">@item.ContactDetails</p>
                </div>

                <div style="margin-bottom:15px;">
                    <span class="label">Region</span>
                    <p style="margin:0;">@item.Region</p>
                </div>

                <!-- ACTIONS -->
                <div style="display:flex; justify-content:space-between; margin-top:15px;">

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn-outline-soft">View</a>

                    <div>
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn-outline-soft">Edit</a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn-outline-soft"
                           style="margin-left:5px;">Delete</a>
                    </div>

                </div>

            </div>

        </div>
    }

</div>