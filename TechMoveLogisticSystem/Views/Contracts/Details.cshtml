@model TechMoveLogisticSystem.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="details-container">

    <!-- HEADER -->
    <div class="details-header">
        <h2>Contract Details</h2>

        <div class="details-actions">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-soft">Edit</a>
            <a asp-action="Index" class="btn-outline-soft">Back</a>
        </div>
    </div>

    <!-- CONTRACT CARD -->
    <div class="contract-card">

        <!-- TOP ROW -->
        <div class="contract-top">
            <div>
                <span class="label">Contract ID</span>
                <h4>@Model.Id</h4>
            </div>

            <div>
                @{
                    var statusClass = "badge-draft";
                    if (Model.Status == "Active") statusClass = "badge-active";
                    else if (Model.Status == "Expired") statusClass = "badge-expired";
                    else if (Model.Status == "On Hold") statusClass = "badge-hold";
                }

                <span class="badge @statusClass">@Model.Status</span>
            </div>
        </div>

        <hr />

        <!-- SECTION: DATES -->
        <div class="contract-section">
            <h5>Contract Period</h5>

            <div class="info-grid">
                <div>
                    <span class="label">Start Date</span>
                    <p>@Model.StartDate.ToString("dd MMM yyyy • HH:mm")</p>
                </div>

                <div>
                    <span class="label">End Date</span>
                    <p>@Model.EndDate.ToString("dd MMM yyyy • HH:mm")</p>
                </div>
            </div>
        </div>

        <div class="contract-divider"></div>

        <!-- SECTION: DETAILS -->
        <div class="contract-section">
            <h5>Contract Details</h5>

            <div class="info-grid">
                <div>
                    <span class="label">Service Level</span>
                    <p>@Model.ServiceLevel</p>
                </div>

                <div>
                    <span class="label">Client</span>
                    <p>@Model.Client.Name</p>
                </div>
            </div>
        </div>

        <div class="contract-divider"></div>

        <!-- SECTION: FILE -->
        <div class="contract-section">
            <h5>Agreement Document</h5>

            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <a href="@Model.SignedAgreementPath" target="_blank" class="file-link">
                    📄 @Model.SignedAgreementFileName
                </a>
            }
            else
            {
                <p class="text-muted">No file uploaded</p>
            }
        </div>

    </div>

</div>