@model TechMoveLogisticSystem.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="form-container">

    <div class="form-card">

        <!-- HEADER -->
        <div class="form-header">
            <h2 class="form-title">Edit Contract</h2>
            <a asp-action="Index" class="btn-outline-soft">Back</a>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <!-- DATES -->
            <div class="form-group">
                <label asp-for="StartDate"></label>
                <input asp-for="StartDate" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="EndDate"></label>
                <input asp-for="EndDate" class="form-control" />
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label asp-for="Status"></label>
                <select asp-for="Status" class="form-control">
                    <option value="Draft">Draft</option>
                    <option value="Active">Active</option>
                    <option value="Expired">Expired</option>
                    <option value="On Hold">On Hold</option>
                </select>
            </div>

            <!-- SERVICE LEVEL -->
            <div class="form-group">
                <label asp-for="ServiceLevel"></label>
                <select asp-for="ServiceLevel" class="form-control">
                    <option value="Standard">Standard</option>
                    <option value="International">International</option>
                </select>
            </div>

            <!-- CLIENT -->
            <div class="form-group">
                <label asp-for="ClientId"></label>
                <select asp-for="ClientId" asp-items="ViewBag.ClientId" class="form-control"></select>
            </div>

            <!-- FILE -->
            <div class="form-group">
                <label>Signed Agreement</label>

                <input asp-for="SignedAgreementFile" type="file" class="form-control" />

                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                {
                    <div class="file-note" style="margin-top:5px;">
                        Current file:
                        <a href="@Model.SignedAgreementPath" target="_blank">
                            @Model.SignedAgreementFileName
                        </a>
                    </div>
                }
            </div>

            <!-- ACTIONS -->
            <div class="form-actions">
                <a asp-action="Index" class="btn-outline-soft">Cancel</a>
                <button type="submit" class="btn-soft">Save Changes</button>
            </div>

        </form>

    </div>
</div>