@model TechMoveLogisticSystem.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="form-container">

    <div class="form-card">

        <!-- HEADER -->
        <div class="form-header">
            <h2 class="form-title">Create Contract</h2>
            <a asp-action="Index" class="btn-outline-soft">Back</a>
        </div>

        <form asp-action="Create" enctype="multipart/form-data">

            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- DATES -->
            <div class="form-group">
                <label asp-for="StartDate"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EndDate"></label>
                <input asp-for="EndDate" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <!-- STATUS -->
            <div class="form-group">
                <label asp-for="Status"></label>
                <select asp-for="Status" class="form-control">
                    <option value="">-- Select Status --</option>
                    <option>Draft</option>
                    <option>Active</option>
                    <option>Expired</option>
                    <option>On Hold</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <!-- SERVICE LEVEL -->
            <div class="form-group">
                <label asp-for="ServiceLevel"></label>
                <select asp-for="ServiceLevel" class="form-control">
                    <option value="">-- Select Service Level --</option>
                    <option value="Standard">Standard</option>
                    <option value="International">International</option>
                </select>
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>

            <!-- CLIENT -->
            <div class="form-group">
                <label asp-for="ClientId"></label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <!-- FILE -->
            <div class="form-group">
                <label>Signed Agreement</label>
                <div class="file-note">Upload contract agreement in PDF format only</div>

                <input asp-for="SignedAgreementFile" type="file" class="form-control" />
                <span asp-validation-for="SignedAgreementFile" class="text-danger"></span>
            </div>

            <!-- ACTIONS -->
            <div class="form-actions">
                <a asp-action="Index" class="btn-outline-soft">Cancel</a>
                <button type="submit" class="btn-soft">Create Contract</button>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}