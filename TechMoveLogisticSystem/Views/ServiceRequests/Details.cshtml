@model TechMoveLogisticSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Request Details";
}

<div class="details-container">

    <div class="details-header">
        <h2>Service Request</h2>

        <a asp-action="Index" class="btn-outline-soft">Back</a>
    </div>

    <div class="contract-card">

        <div class="contract-top">
            <h4>@Model.Description</h4>

            @{
                var status = Model.Status;
                var badgeClass = "badge-draft";

                if (status == "Completed") badgeClass = "badge-active";
                else if (status == "In Progress") badgeClass = "badge-hold";
                else if (status == "Pending") badgeClass = "badge-draft";
            }

            <span class="badge @badgeClass">@status</span>
        </div>

        <div class="contract-divider"></div>

        <div class="contract-section">
            <h5>Financial Breakdown</h5>

            <div class="info-grid">

                <div>
                    <span class="label">USD Cost</span>
                    <p>$ @((Model.Cost / (decimal)ViewBag.Rate).ToString("N2"))</p>
                </div>

                <div>
                    <span class="label">ZAR Equivalent</span>
                    <p>R @Model.Cost.ToString("N2")</p>
                </div>

            </div>
        </div>

        <div class="contract-divider"></div>

        <div class="contract-section">
            <h5>Contract Info</h5>

            <div class="info-grid">
                <div>
                    <span class="label">Contract ID</span>
                    <p>@Model.Contract.Id</p>
                </div>

                <div>
                    <span class="label">Service Level</span>
                    <p>@Model.Contract.ServiceLevel</p>
                </div>

                <div>
                    <span class="label">Client</span>
                    <p>@Model.Contract.Client.Name</p>
                </div>
            </div>
        </div>

        <div class="contract-divider"></div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-soft">Edit</a>
            <a asp-action="Index" class="btn-outline-soft">Back</a>
        </div>

    </div>
</div>